{
  "name": "vigil",
  "version": "1.0.0",
  "description": "GSS wrapper layer to serve content from all microservices through GraphQL and REST API",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "build": "swc src -d dist",
    "build-dev": "npm run build && cross-env NODE_ENV=development node --inspect --experimental-specifier-resolution=node dist/src/index.js",
    "dev": "nodemon --ext ts --watch src --exec \"npm run build-dev\"",
    "start": "npm run build && cross-env NODE_ENV=production node dist/src/index.js",
    "worker:email": "nodemon src/utils/queue.ts",
    "test": "majestic"
  },
  "author": "yasaswini-tech01 <Yasaswini.Kothamasu@vithiit.com>",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@aws-sdk/client-s3": "^3.740.0",
    "@mercury-js/core": "^2.0.1",
    "@mercury-js/plugins": "^1.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^16.11.11",
    "apollo-server-express": "^3.5.0",
    "axios": "^0.24.0",
    "bullmq": "^5.44.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^3.14.0",
    "express": "^4.17.1",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^7.5.0",
    "fakerator": "^0.3.6",
    "googleapis": "^170.0.0",
    "graphql": "^16.0.1",
    "graphql-import": "^1.0.2",
    "graphql-middleware": "^6.1.35",
    "graphql-rate-limit": "^3.3.0",
    "graphql-tools": "^9.0.11",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "merge-graphql-schemas": "^1.7.8",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "nodemon": "^2.0.15",
    "open": "^10.2.0",
    "pdf-parse": "^2.2.16",
    "rate-limiter-flexible": "^5.0.5",
    "redis": "^4.7.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.3.0",
    "typescript": "^4.5.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.11",
    "@swc/jest": "^0.2.11",
    "@types/axios": "^0.14.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.13",
    "@types/express-fileupload": "^1.5.1",
    "@types/graphql": "^14.5.0",
    "@types/jest": "^27.0.3",
    "@types/lodash": "^4.14.177",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^2.0.11",
    "cross-env": "^10.1.0",
    "jest": "^27.4.3",
    "majestic": "^1.8.1",
    "supertest": "^6.1.6",
    "ts-node": "^10.4.0"
  },
  "majestic": {
    "jestScriptPath": "./node_modules/jest/bin/jest.js",
    "args": [
      "--config=./jest.config.cjs"
    ],
    "env": {
      "CI": "true"
    }
  }
